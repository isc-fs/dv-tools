# Frontend
node_modules/
dist/

# Tauri build outputs (the workspace's target/ at mingoros/ already catches the
# Rust side; these are anything Tauri or the bundler drops inside src-tauri/).
src-tauri/target/
src-tauri/gen/

# Tauri icon-generation outputs that aren't the source `icon.png`.
# `tauri icon` rebuilds these on demand from icon.png; committing them just
# creates merge conflicts. (Local devs + CI regenerate them.)
src-tauri/icons/icon.icns
src-tauri/icons/icon.ico
src-tauri/icons/Square*.png
src-tauri/icons/StoreLogo.png
src-tauri/icons/32x32.png
src-tauri/icons/64x64.png
src-tauri/icons/128x128.png
src-tauri/icons/128x128@2x.png
src-tauri/icons/android/
src-tauri/icons/ios/

# Per-app npm lockfile appears after `npm install` runs in this dir.
package-lock.json

# Editor / OS noise
.vscode/settings.json
.DS_Store
