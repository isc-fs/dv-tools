{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MingoROS Studio",
  "version": "0.1.0",
  "identifier": "fs.isc.mingoros.studio",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MingoROS · DV state",
        "width": 1120,
        "height": 840,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
