{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ISC MingoROS",
  "version": "0.4.6",
  "identifier": "fs.isc.mingoros.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ISC MingoROS",
        "width": 1200,
        "height": 860,
        "minWidth": 860,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/isc-fs/dv-tools/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2NTZDODYwMDA2QTFENzIKUldSeUhXb0FZTWhXaHFQSTAxWHY0S0FPbHArQUVTQzlvOFRBb3UzZ1ExVmh2cEUrMVJaNU1oYnMK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "appimage", "deb", "rpm", "nsis"],
    "category": "DeveloperTool",
    "copyright": "Copyright © 2026 ISC Racing Team — IFS08 Driverless",
    "shortDescription": "Debug the DV state machine + safety systems on a stopped car.",
    "longDescription": "ISC MingoROS is the desktop companion to the mingoros CLI: a native Go/No-Go board that joins the car's ROS 2 DDS graph over Ethernet and shows the autonomous state machine, EBS / RES / ASMS safety interlocks, and mission state at a glance — for bench commissioning of a stationary Formula Student driverless car. Cross-platform native via Tauri 2.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "entitlements.plist"
    }
  }
}
